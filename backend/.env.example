# 复制为 .env 后填写：https://help.aliyun.com/zh/model-studio/developer-reference/get-api-key
DASHSCOPE_API_KEY=

# 推荐：DashScope OpenAI 兼容模式（与下面二选一逻辑：有 OPENAI_LLM_BASE_URL 则走兼容 HTTP，否则走 ChatTongyi SDK）
OPENAI_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_LLM_MODEL=qwen-plus

# 未配置 OPENAI_LLM_BASE_URL / MODEL 时的通义模型名（仅原生 Tongyi 路径使用）
QWEN_MODEL=qwen-plus
